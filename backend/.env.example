# ─── AgroTree Backend Environment Variables ───
# Salin file ini menjadi .env lalu isi dengan nilai Anda sendiri.

# Port server backend (default: 8088)
PORT=8088

# JWT Secret Key (WAJIB diganti untuk production!)
JWT_SECRET=ganti-dengan-secret-key-anda-yang-kuat

# Google Gemini API Key (diperlukan untuk fitur AI Chatbot)
# Dapatkan di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# CORS Allowed Origins (pisahkan dengan koma)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
